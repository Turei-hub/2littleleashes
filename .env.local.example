# ─── Email (Nodemailer) ────────────────────────────────────────────────────────
# Use Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# The business owner's email — all booking alerts land here.
# IMPORTANT: this must be a bare email address, NOT the website URL.
# Do not paste the site domain (e.g. www.2littleleashes...) — that produces
# an invalid recipient like "www.2littleleashes@gmail.com" and the alert bounces.
OWNER_EMAIL=2littleleashes@gmail.com
# Optional second recipient for booking alerts (leave unset if not needed)
# OWNER_EMAIL_2=

# The "from" address shown to customers
FROM_EMAIL="2 Little Leashes <meihana@2littleleashes.co.nz>"

# ─── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
